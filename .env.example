# Copy to `.env` or `.env.local` in the project root (same folder as package.json).
# Next.js does NOT load `.env.example` — only `.env`, `.env.local`, `.env.development`, etc.
# After changing env files, restart: npm run dev

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
# Gmail app passwords are 16 characters; spaces are OK if your .env line keeps them
SMTP_PASS=your-app-password

CONTACT_TO_EMAIL=where-to-receive@example.com
MAIL_FROM="Xeda Farm <your-email@gmail.com>"

# Optional aliases (if you already use these names elsewhere):
# SMTP_HOST ← EMAIL_HOST, MAIL_HOST
# SMTP_USER ← SMTP_USERNAME, EMAIL_USER, MAIL_USERNAME
# SMTP_PASS ← SMTP_PASSWORD, EMAIL_PASSWORD, MAIL_PASSWORD
# CONTACT_TO_EMAIL ← MAIL_TO, TO_EMAIL, INQUIRY_EMAIL
# MAIL_FROM ← SMTP_FROM, FROM_EMAIL, EMAIL_FROM
